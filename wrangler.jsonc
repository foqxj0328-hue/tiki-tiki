{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "tiki-tiki",
  "main": "./src/worker.js",
  "compatibility_date": "2026-06-22",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "html_handling": "force-trailing-slash",
    "not_found_handling": "404-page",
    "run_worker_first": [
      "/downloads/*",
      "/api/*",
      "/download-assets/*"
    ]
  },
  "observability": {
    "enabled": true
  }
}
